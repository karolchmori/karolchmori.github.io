---
// About.astro
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import Vignette from '../components/widgets/Vignette.astro';
import SpecialityItem from '../components/props/SpecialityItem.astro';
import { SITE_DESCRIPTION, SITE_TITLE, DEMOREEL } from '../consts';

import { VideoEmbed, Collapsible, Callout, CodeBlock, PictureCompare, 
    DynamicTable, IconList, PictureSequence, Columns, Column, Picture, VideoPlayer
 } from '../components/mdx-components';

---
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<div class="about-container">
			<main>
				<section class="about-page">
					<div class="prose">
						<!-- HEADER -->
						<div class="about-banner">
							<div class="banner-photo">
								<!-- Replace with <img src="..." alt="Karol Ch. Mori" /> -->
								<div class="avatar-placeholder">KM</div>
							</div>
							<div class="banner-meta">
								<h1 class="about-name">Karol Ch. Mori</h1>
								<span class="eyebrow">Pipeline &amp; Tools TD</span>
 
								<div class="contact-list">
									<a href="mailto:karolchmori@hotmail.com" class="contact-row">
										<svg class="contact-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 6h18v12H3V6Zm0 0 9 7 9-7" stroke-linecap="round" stroke-linejoin="round"/></svg>
										karolchmori@hotmail.com
									</a>
									<a href="https://github.com/karolchmori" class="contact-row" target="_blank" rel="noopener">
										<svg class="contact-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 19c-4.3 1.4-4.3-2.5-6-3m12 5v-3.5c0-1 .1-1.4-.5-2 2-.2 4.5-1 4.5-4.5 0-1-.4-2-1-2.7.1-.3.5-1.5-.1-3.2 0 0-1.2-.4-3.9 1.5a13.4 13.4 0 0 0-7 0C4.4 5.1 3.2 5.5 3.2 5.5c-.6 1.7-.2 2.9-.1 3.2A4.1 4.1 0 0 0 2 11.4c0 3.5 2.5 4.3 4.5 4.5-.4.4-.4 1-.5 1.6V21" stroke-linecap="round" stroke-linejoin="round"/></svg>
										karolchmori
									</a>
									<a href="https://linkedin.com/in/karolchmori" class="contact-row" target="_blank" rel="noopener">
										<svg class="contact-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M7 10v6M7 7v.01M11 16v-4a2 2 0 0 1 4 0v4M11 12v4" stroke-linecap="round" stroke-linejoin="round"/></svg>
										karolchmori
									</a>
								</div>
 
								<div class="banner-actions">
									<a href="/karolchmori-cv.pdf" class="btn btn-secondary" download>
										<svg class="btn-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 3v12m0 0 4-4m-4 4-4-4M4 18v2a1 1 0 0 0 1 1h14a1 1 0 0 0 1-1v-2" stroke-linecap="round" stroke-linejoin="round"/></svg>
										Download CV
									</a>
									<a href="mailto:karolchmori@hotmail.com" class="btn btn-primary">Get in touch</a>
								</div>
							</div>
						</div>

						<div class="divider"></div>

						<!-- DESCRIPTION -->
						<p class="about-bio">
							I'm a Pipeline &amp; Tools TD with a background in technical project management.
							I build the tools and systems that keep artists and productions moving — from
							procedural Houdini setups to the publish pipelines around them. Comfortable
							moving between DCC scripting and the production side of a studio.
						</p>

						<!-- SKILLS -->
						<div class="section-label">SPECIALITIES</div>
						<Columns stackOnMobile>
							<Column>
								<SpecialityItem title='Tools Development' description='Python and C++ tooling for artists: custom DCCs, shelf tools, validators, and procedural systems.'/>
							</Column>
							<Column>
								<SpecialityItem title='Pipeline TD' description='End-to-end pipeline design and automation. Asset management, publish systems, and cross-DCC interop for film, TV, and games.'/>
							</Column>
							<Column>
								<SpecialityItem title='Project Management' description='Production planning, team coordination and technical roadmaps. Keeping creative teams unblocked and shipping on time.'/>
							</Column>
						</Columns>

						<div class="divider"></div>

						<!-- SOFTWARE -->
						<!-- SKILLS & SOFTWARE, grouped by category, no proficiency labels -->
						<div class="section-label">Skills &amp; Software</div>
						<div class="skills-grid">
							<div class="skill-group">
								<span class="skill-group-label">Pipeline &amp; Tools</span>
								<div class="chip-row">
									<span class="chip">USD</span>
									<span class="chip">Git</span>
									<span class="chip">GitHub</span>
									<span class="chip">Qt / PySide</span>
									<span class="chip">WPF</span>
								</div>
							</div>
							<div class="skill-group">
								<span class="skill-group-label">Programming &amp; Scripting</span>
								<div class="chip-row">
									<span class="chip">Python</span>
									<span class="chip">C++</span>
									<span class="chip">VEX</span>
									<span class="chip">C#</span>
									<span class="chip">Java</span>
									<span class="chip">Dart</span>
								</div>
							</div>
							<div class="skill-group">
								<span class="skill-group-label">DCC &amp; Creative Tools</span>
								<div class="chip-row">
									<span class="chip chip-accent">Houdini</span>
									<span class="chip chip-accent">Maya</span>
									<span class="chip">Nuke</span>
									<span class="chip">Substance Painter</span>
									<span class="chip">Unreal Engine</span>
									<span class="chip">Photoshop</span>
								</div>
							</div>
							<div class="skill-group">
								<span class="skill-group-label">Production &amp; PM</span>
								<div class="chip-row">
									<span class="chip">Jira</span>
									<span class="chip">ShotGrid</span>
									<span class="chip">Notion</span>
									<span class="chip">Confluence</span>
									<span class="chip">Agile / Scrum</span>
								</div>
							</div>
						</div>

						<div class="divider"></div>

						<!-- WORK EXPERIENCE + EDUCATION, side by side, light touch -->
						<div class="split-columns">
							<div>
								<div class="section-label">Work Experience</div>
								<div class="timeline">
									<div class="timeline-item">
										<span class="timeline-dot timeline-dot-current"></span>
										<span class="timeline-title">Technical Project Manager</span>
										<span class="timeline-sub">Esteve Teijin · 2021 – Present</span>
									</div>
									<div class="timeline-item">
										<span class="timeline-dot"></span>
										<span class="timeline-title">IT Help Desk</span>
										<span class="timeline-sub">Esteve Teijin · 2020 – 2021</span>
									</div>
								</div>
							</div>
							<div>
								<div class="section-label">Education</div>
								<div class="timeline">
									<div class="timeline-item">
										<span class="timeline-dot timeline-dot-current"></span>
										<span class="timeline-title">B. 3D Animation &amp; VFX</span>
										<span class="timeline-sub">La Salle URL · 2017 – Present</span>
									</div>
									<div class="timeline-item">
										<span class="timeline-dot"></span>
										<span class="timeline-title">Associate in Programming</span>
										<span class="timeline-sub">Salesians Sarrià · 2019 – 2021</span>
									</div>
								</div>
							</div>
						</div>
 
						<div class="divider"></div>
 
						<!-- LANGUAGES -->
						<div class="section-label">Languages</div>
						<div class="lang-grid">
							<div class="lang-item">
								<span class="lang-name">Spanish</span>
								<span class="lang-level">Native</span>
							</div>
							<div class="lang-item">
								<span class="lang-name">English</span>
								<span class="lang-level">Fluent</span>
							</div>
							<div class="lang-item">
								<span class="lang-name">Catalan</span>
								<span class="lang-level">Fluent</span>
							</div>
							<div class="lang-item">
								<span class="lang-name">Japanese</span>
								<span class="lang-level">Elementary</span>
							</div>
						</div>

					</div>
					

				</section>

			</main>
		</div>
		<Footer />
		<Vignette />
	</body>
</html>





<style>

	html, body {
		margin: 0;
		padding: 0;
		min-height: 100%;
	}

	.about-container {
		position: relative;
		min-height: 100vh;      /* ← container itself must have a height to push against */
		display: flex;
		flex-direction: column;
	}

	.about-container::before {
		content: "";
		position: fixed;
		inset: 0;
		background-image: url('../assets/BG/BG_High.jpg');
		background-repeat: no-repeat;
		background-size: cover;
		background-position: top center;
		z-index: -1;
	}

	main {
		position: relative;
		z-index: 1;
		width: calc(100% - 2em);
		max-width: 100%;
		margin: 0 auto;
		flex: 1;                /* ← takes remaining space inside tool-container */
		display: flex;
		flex-direction: column;
	}
 

	.about-page {
		background-color: #e8e3e6;
		border-radius: 16px;
		max-width: 900px;
		width: 100%;
		margin: 1rem auto;
		overflow: hidden;
		flex: 1;     
		display: flex;
		flex-direction: column;
		
	}

	.prose {
		width: auto;
		max-width: 90%;
		margin: auto;
		padding: 0.5em;
		color: rgb(var(--gray-dark));
	}


	/* ── HEADER ── */
	/* ── BANNER ── */
	.about-banner {
		display: flex;
		gap: 1.5rem;
		align-items: flex-start;
		background: color-mix(in srgb, var(--color-primary) 14%, var(--comp-bg-white));
		border-radius: 14px;
		padding: 1.75rem;
		margin: 1.5rem 0;
	}
 
	.banner-photo {
		flex-shrink: 0;
	}
 
	.avatar-placeholder {
		width: 96px;
		height: 96px;
		border-radius: 50%;
		background: var(--comp-bg-gray);
		border: 2px solid var(--comp-border-gray);
		display: flex;
		align-items: center;
		justify-content: center;
		font-size: 1.3rem;
		font-weight: 700;
		color: var(--gray-medium);
	}
 
	.about-name {
		font-size: 1.9rem;
		font-weight: 700;
		line-height: 1.1;
		margin: 0 0 0.3rem;
		color: var(--black);
	}
 
	.eyebrow {
		display: block;
		font-size: 0.7rem;
		font-family: monospace;
		letter-spacing: 0.15em;
		text-transform: uppercase;
		color: var(--color-primary);
		margin-bottom: 0.9rem;
	}
 
	.contact-list {
		display: flex;
		flex-direction: column;
		gap: 0.4rem;
		margin-bottom: 1.1rem;
	}
 
	.contact-row {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		font-size: 0.82rem;
		color: var(--gray-medium);
		text-decoration: none;
	}
 
	.contact-row:hover {
		color: var(--color-primary);
	}
 
	.contact-icon {
		width: 15px;
		height: 15px;
		flex-shrink: 0;
		color: var(--gray-light);
	}
 
	.banner-actions {
		display: flex;
		gap: 0.65rem;
	}
 
	.btn {
		display: inline-flex;
		align-items: center;
		gap: 0.4rem;
		font-size: 0.82rem;
		font-weight: 600;
		padding: 0.5rem 0.9rem;
		border-radius: 8px;
		text-decoration: none;
		transition: opacity 0.15s ease, background 0.15s ease;
	}
 
	.btn-icon {
		width: 14px;
		height: 14px;
	}
 
	.btn-secondary {
		background: var(--comp-bg-white);
		border: 1px solid var(--comp-border-gray);
		color: var(--gray-dark);
	}
 
	.btn-secondary:hover {
		background: var(--comp-bg-gray);
	}
 
	.btn-primary {
		background: var(--color-primary);
		color: #fff;
		border: 1px solid var(--color-primary);
	}
 
	.btn-primary:hover {
		background: var(--accent-dark);
		border-color: var(--accent-dark);
	}
 
	/* ── BIO ── */
	.about-bio {
		font-size: 0.95rem;
		line-height: 1.75;
		color: var(--gray-medium);
		max-width: 560px;
		margin: 0 0 0.5rem;
	}








	/* ── DIVIDER ── */
	.divider {
		height: 1px;
		background: var(--comp-border-gray);
		margin: 2rem 0;
	}
	
	/* ── SECTION LABEL ── */
	.section-label {
		font-family: monospace;
		font-size: 0.65rem;
		letter-spacing: 0.2em;
		text-transform: uppercase;
		color: var(--gray-light);
		margin-bottom: 1.25rem;
	}
	
	/* ── SKILLS ── */


	/* ── SOFTWARE ── */
	.skills-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 1.5rem 2rem;
	}
 
	.skill-group-label {
		display: block;
		font-size: 0.78rem;
		font-weight: 700;
		color: var(--gray-dark);
		margin-bottom: 0.65rem;
	}
 
	.chip-row {
		display: flex;
		flex-wrap: wrap;
		gap: 0.45rem;
	}
 
	.chip {
		font-size: 0.75rem;
		padding: 0.3rem 0.7rem;
		border-radius: 20px;
		background: var(--comp-bg-gray);
		color: var(--gray-medium);
	}
 
	.chip-accent {
		background: color-mix(in srgb, var(--color-primary) 14%, var(--comp-bg-white));
		color: var(--color-primary);
	}
	
	/* ── LANGUAGES ── */
	.split-columns {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 2.5rem;
	}
 
	.timeline {
		display: flex;
		flex-direction: column;
		gap: 1.1rem;
		position: relative;
		padding-left: 1.1rem;
		border-left: 1px solid var(--comp-border-gray);
	}
 
	.timeline-item {
		display: flex;
		flex-direction: column;
		gap: 0.15rem;
		position: relative;
	}
 
	.timeline-dot {
		position: absolute;
		left: -1.35rem;
		top: 0.25rem;
		width: 7px;
		height: 7px;
		border-radius: 50%;
		background: var(--comp-border-gray);
	}
 
	.timeline-dot-current {
		background: var(--color-primary);
	}
 
	.timeline-title {
		font-size: 0.85rem;
		font-weight: 700;
		color: var(--black);
	}
 
	.timeline-sub {
		font-size: 0.72rem;
		color: var(--gray-light);
		font-family: monospace;
	}
 
	/* ── LANGUAGES ── */
	.lang-grid {
		display: flex;
		gap: 2rem;
		flex-wrap: wrap;
	}
 
	.lang-item {
		display: flex;
		flex-direction: column;
		gap: 0.2rem;
	}
 
	.lang-name {
		font-size: 0.875rem;
		font-weight: 600;
		color: var(--black);
	}
 
	.lang-level {
		font-size: 0.75rem;
		color: var(--gray-light);
		font-family: monospace;
	}
	
	/* ── RESPONSIVE ── */
	@media (max-width: 640px) {
		.about-header { flex-direction: column-reverse; }
		.skills-grid { grid-template-columns: 1fr; }
		.software-grid { grid-template-columns: 1fr; }
		.timeline-item { grid-template-columns: 1fr; gap: 0.25rem; }
		.timeline-date { padding-top: 0; }
	}
</style>
 