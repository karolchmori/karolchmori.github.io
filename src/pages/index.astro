---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import MainBackCards from '../assets/elements/Main_BackCards.png';
import MainFrontCard from '../assets/elements/Main_FrontCard.png';
import ScrollDownArrow from '../assets/icons/AS_DownArrow.svg';
import "../styles/animations.css";
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<div class="home-container">
					<main>
			<section class="home-hero">
				<a class="home-backcards">
					<img src={MainBackCards.src} alt="" />
				</a>
				<a class="home-maincard">
					<img src={MainFrontCard.src} alt="" />
				</a>
				<div class="scroll-arrow">
					<img src={ScrollDownArrow.src} alt="" />
				</div>
			</section>
			<section class="home-transition">

			</section>
			<section class="home-portfolio">


			</section>
		</main>

		</div>

		<Footer />
	</body>
</html>


<style> 
	.home-container {
		background-image: url('../assets/BG/MainHomeAll_BG_High.jpg');
		background-repeat: no-repeat;
		background-size: cover;
		background-position: top center;
	}


	.home-hero {
		position: relative;
  		min-height: 100vh;
		
	}

	.home-backcards img,
	.home-maincard img {
		width: auto;
		height: 100vh;
		max-width: none;
		display: block;
	}

	.scroll-arrow img {
		width: auto;
		height: 3.2vh;
	}

	.home-backcards, .home-maincard {
		position: absolute;
		top: 50%;
		left: 50%;
		transform: translate(-50%, -50%) 
					scale(clamp(0.1, 
						min(calc(100vh / 771px), calc(100vw / 300px)), 
						0.75));
		transform-origin: center;
	}

	.scroll-arrow {
		/* Transform */ 
		position: absolute;
		bottom: 7%;
		left: 50%;
		z-index: 5;
		
		/* Animation */ 
		--bounce-height: 10px;
		animation: bounce 2s infinite;

		/* Filter */ 
		filter: drop-shadow(0 0 10px #ff7ec7);
	}
	

	@media (max-width: 768px) {
		.home-backcards, .home-maincard {
			position: absolute;
			top: 40%;
			left: 50%;
			transform: translate(-50%, -50%) 
						scale(clamp(0.1, 
						min(calc(100vh / 771px), calc(100vw / 300px)), 
						0.55));
			transform-origin: center;
		}

		.scroll-arrow {
			bottom: 23%;
			left: 47%;
		}

	}









	.home-transition {
		min-height: 54vh;
		width: 100%;
	}

	.home-portfolio {
		min-height: 100vh;
		width: 100%;
	}

	section {
		display: block; 
	}


	body {
		margin: 0;
		padding: 0;
	}

	main {
		width: 100%;
		max-width: 100%;
		margin: 0;
		padding: 0;
	}

</style>
