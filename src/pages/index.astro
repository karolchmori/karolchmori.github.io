---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE, DEMOREEL } from '../consts';
import "../styles/animations.css";

import MainBackCards from '../assets/elements/Main_BackCards.png';
import MainFrontCard from '../assets/elements/Main_FrontCard.png';
import PlayButton from '../assets/icons/AS_PlayButton.svg';


import VideoModal from '../components/widgets/VideoModal.astro';
import ArrowButton from '../components/widgets/ArrowButton.astro';
import Vignette from '../components/widgets/Vignette.astro';
import HorizontalCarousel from '../components/widgets/HorizontalCarousel.astro';

import SoftwareChip from '../components/props/SoftwareChip.astro';
import ToolCard from '../components/props/ToolCard.astro';

import { getActiveTools } from '../data/ToolLibrary';
const activeTools = getActiveTools();


import { getCollection } from 'astro:content';
const toolEntries = (await getCollection('tool'))
    .filter(entry => entry.data.featured)
    .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());


---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<div class="home-container">
			<main>
				<section class="home-hero">
					<a class="home-backcards">
						<img src={MainBackCards.src} alt="" />
					</a>
					<a class="home-maincard" id="mainCard">
						<img class="home-maincard-bg" src={MainFrontCard.src} alt="" />
						<span class="home-showreelPlay">
							<img src={PlayButton.src} alt="" />
						</span>
					</a>
					<VideoModal trigger="#mainCard" platform="vimeo" idVideo={DEMOREEL}/>
					<div class="scroll-arrow"> 
						<ArrowButton variant='glow'/>
					</div>
				</section>
				<section class="home-portfolio">
					<a class="home-portfolio-title">
						<span class="home-portfolio-title-small">MY</span>TOOLS
					</a>
					 <HorizontalCarousel class="tool-card-placeholder" itemSize='34vh' gap={2} navigation='buttons' buttonPosition="top" buttonJustify='right'>
						<ToolCard index={0}/>
					</HorizontalCarousel>
					<HorizontalCarousel class="tool-card-selected" itemSize='34vh' gap={2} navigation="buttons" buttonPosition="top" buttonJustify='right'>
						{toolEntries.map((entry, i) => (
							<ToolCard entry={entry} index={i}/>
						))}
					</HorizontalCarousel>

					<HorizontalCarousel class="home-softwareChips" itemSize='11vh' gap={1}>
						{activeTools.map(tool => <SoftwareChip tool={tool} />)}
					</HorizontalCarousel>

				</section>
				<section class="home-credits">


				</section>
				<section class="home-ending">


				</section>
			</main>
		</div>
		<Footer class="home-social"/>
		<Vignette />
	</body>
</html>


<style> 

	body {
		-webkit-tap-highlight-color: transparent;
		-webkit-user-drag: none;
		-webkit-touch-callout: none;
		-webkit-user-select: none;
	}


	/* -------------------------------------------------------------- */ 
	/* ---------------------- MAIN SECTIONS ------------------------- */ 
	/* -------------------------------------------------------------- */ 
	.home-container::before {
		content: "";
		position: absolute;
		inset: 0;

		background-image: url('../assets/BG/BG_MainHome_High.jpg');
		background-repeat: no-repeat;
		background-size: cover;
		background-position: top center;

		filter: blur(0.7px);
		transform: scale(1.005);

		z-index: -1;
	}

	.home-container {
		position: relative;
		overflow: hidden;
	}

	.home-hero {
		position: relative;
  		min-height: 100vh;
	}

	.home-portfolio {
		position: relative;
		min-height: 100vh;
		width: 100%;
		/*background-color: rgba(72, 255, 0, 0.13);*/

		display: flex;
		flex-direction: column;
		justify-content: center;
		align-items: center;
	}

	.home-credits {
		min-height: 100vh;
		width: 100%;
	}

	.home-ending {
		min-height: 39vh;
		width: 100%;
	}

	section {
		display: block;
		scroll-snap-align: start;
	}


	body {
		margin: 0;
		padding: 0;
	}

	main {
		width: 100%;
		max-width: 100%;
		margin: 0;
		padding: 0;
	}


	/* -------------------------------------------------------------- */ 
	/* ------------------------ HERO CONFIG ------------------------- */ 
	/* -------------------------------------------------------------- */ 

	.home-maincard img{
		width: auto;
		height: auto;
		max-width: 70vw;
		max-height: 65vh;
		display: block;
	}

	.home-backcards img {
		width: auto;
		height: auto;
		max-width: 80vw;
		max-height: 70vh;
		display: block;
		filter: blur(0.5px);
	}

	.home-showreelPlay img {
		width: auto;
		height: 14vh;
	}

	.home-backcards, .home-maincard {
		position: absolute;
		top: 47%;
		left: 50%;
		transform: translate(-50%, -50%);
	}

	.home-showreelPlay {
		position: absolute;
		top: 48%;
		left: 50%;
		transform: translate(-50%, -50%);
		transform-origin: center;
		pointer-events: none;
		opacity: 0;
		transition: opacity 0.7s cubic-bezier(0.22, 1, 0.36, 1);
		
	}

	.home-maincard:hover .home-maincard-bg {
		filter: blur(2px) brightness(70%);
		cursor: pointer;
	}


	.home-maincard:hover .home-showreelPlay {
		opacity: 1;
		filter: blur(1px);
		pointer-events: auto;
		cursor: pointer;
	}

	/* ---------------------- Scroll Arrow ----------------------- */ 
	.scroll-arrow {
		/* Transform */ 
		position: absolute;
		bottom: 7%;
		left: 49%;
		transform: translate(-50%, -50%);
		transform-origin: center;
		z-index: 5;
		
		/* Animation */ 
		--bounce-height: 10px;
		animation: bounce 2s infinite;	
	}




	/* -------------------------------------------------------------- */ 
	/* ---------------------- PORTFOLIO CONFIG ---------------------- */ 
	/* -------------------------------------------------------------- */ 

	.home-portfolio {
		display: flex;
		flex-direction: column;
	}

	.home-portfolio-title {
		position: absolute;
        color: #5f5457; 
		font-family: 'IBM Plex Sans';
		font-weight: 700;
  		font-style: normal;
		font-stretch: condensed;
        font-size: 7vh;


		filter: opacity(70%);
        margin-bottom: 0.1em;
		bottom: 79%;
		user-select: none;
		
	}

	.home-portfolio-title-small {
		font-size: 4.5vh;
		font-weight: 600;
	}


	.home-portfolio :global(.home-softwareChips) {
        position: absolute;
        bottom: 10%;
		z-index: 1;
    }

	.home-portfolio :global(.tool-card-placeholder),
	.home-portfolio :global(.tool-card-selected) {
        position: absolute;
        bottom: 28%;
		z-index: 3;
    }
	
	.home-portfolio :global(.tool-card-selected) {
        display: none;
    }

	/* -------------------------------------------------------------- */ 
	/* ------------------- PHONE MODIFICATIONS ---------------------- */ 
	/* -------------------------------------------------------------- */ 
	

	@media (orientation: portrait), (max-aspect-ratio: 9/16) {

		.home-backcards, .home-maincard {
			top: 41%;
		}


		.home-maincard:hover .home-showreelPlay {
			opacity: 1;
		}

		.home-maincard-bg {
			animation: revealBlur 1.5s cubic-bezier(0.22, 1, 0.36, 1) forwards;
			animation-delay: 4s;
		}

		.home-showreelPlay {
			animation: revealOpacity 2s cubic-bezier(0.22, 1, 0.36, 1) forwards;
			animation-delay: 4s;
			top: 45%;
		}

		.scroll-arrow {
			bottom: 18%;
			left: 47%;
		}

		.home-social { display: none; }

		.home-portfolio :global(.home-softwareChips) {
			bottom: 14%;
		}

		.home-portfolio :global(.tool-card-placeholder),
		.home-portfolio :global(.tool-card-selected) {
			bottom: 31%;
		}

		.home-portfolio-title {
			font-size: 5vh;
			bottom: 82%;
		}

		.home-portfolio-title-small {
			font-size: 3vh;
		}

	}

</style>



<script>
	const arrow = document.querySelector(".scroll-arrow");
	const portfolio = document.querySelector(".home-portfolio");

	let selectedToolId: string;
	let changedPlaceholder = false;

	arrow?.addEventListener("click", () => {
		portfolio?.scrollIntoView({
		behavior: "smooth",
		block: "start",
		});
	});

	

	window.addEventListener("tool:selected", (e) => { 

		const { id } = (e as CustomEvent).detail;
		
		selectedToolId = id;

		if (selectedToolId && !changedPlaceholder) {
			const placeholder = document.querySelector('.tool-card-placeholder') as HTMLElement;
			const selected = document.querySelector('.tool-card-selected') as HTMLElement;

			
			if (placeholder) {
				placeholder.style.animation = 'fadeOut 0.5s cubic-bezier(0.22, 1, 0.36, 1) forwards';
				setTimeout(() => {
					placeholder.style.display = 'none';
				}, 300); // match animation duration
			}

			selected.style.display = 'flex';
		} 

		const allCards = Array.from(document.querySelectorAll<HTMLElement>('.tool-card')).filter(c => c.dataset.software);
		
		// Find the ones matching by software
		const matching = allCards.filter(c => c.dataset.software === id);

		// Hide each that is not matching after the search
		const rest     = allCards.filter(c => c.dataset.software !== id);
		//rest.forEach(c => c.dataset.state = 'hidden');
		rest.forEach((c, i) => {	
			c.dataset.state = 'hidden';
			c.style.display = 'none';
		});
		
	
		// show up to 4 matching as active
		matching.forEach((c, i) => {
			c.style.display = '';
			c.style.setProperty('--card-index', String(i));
			
			setTimeout(() => {
				c.dataset.state = i < 4 ? 'active' : 'hidden';
			}, i * 300);
				
		});

		const selectedTrack = document.querySelector('.tool-card-selected [data-carousel]') as HTMLElement;
		if (selectedTrack) {
			selectedTrack.scrollLeft = 0;
		}

		// After showing/hiding cards, nudge the carousel to remeasure
		requestAnimationFrame(() => requestAnimationFrame(() => {
			document.querySelectorAll<HTMLElement>('[data-carousel]').forEach(track => {
				track.dispatchEvent(new Event('scroll'));
			});
		}));

	});


</script>