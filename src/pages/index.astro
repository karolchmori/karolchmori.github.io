---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE, DEMOREEL } from '../consts';
import "../styles/animations.css";

import MainBackCards from '../assets/elements/Main_BackCards.png';
import MainFrontCard from '../assets/elements/Main_FrontCard.png';
import PlayButton from '../assets/icons/AS_PlayButton.svg';


import Vignette from '../components/props/Vignette.astro';
import VideoModal from '../components/props/VideoModal.astro';
import ArrowButton from '../components/props/ArrowButton.astro';
import SoftwareChip from '../components/props/SoftwareChip.astro';

import { getActiveTools } from '../data/ToolLibrary';
import SoftwareArcSlider from '../components/props/SoftwareArcSlider.astro';
const activeTools = getActiveTools();
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<div class="home-container">
			<main>
				<section class="home-hero">
					<a class="home-backcards">
						<img src={MainBackCards.src} alt="" />
					</a>
					<a class="home-maincard" id="mainCard">
						<img class="home-maincard-bg" src={MainFrontCard.src} alt="" />
						<span class="home-showreelPlay">
							<img src={PlayButton.src} alt="" />
						</span>
					</a>
					<VideoModal trigger="#mainCard" platform="vimeo" idVideo={DEMOREEL}/>
					<div class="scroll-arrow"> 
						<ArrowButton variant='glow'/>
					</div>
				</section>
				<section class="home-transition">
				</section>
				
				<section class="home-portfolio">
					<div class="home-softslider-desktop">
						<SoftwareArcSlider tools={activeTools} iconSize="12vh" startAngle={115}
						widthRes={80} heightRes={30}
						maxRotation={25} totalItems={50} radius='290vh' borderMargin={2.11}/>
					</div>
					<div class="home-softslider-phone">
						<SoftwareArcSlider tools={activeTools} iconSize="14vh" startAngle={90}
						widthRes={80} heightRes={30}
						maxRotation={120} totalItems={50} radius='290vh' borderMargin={2.2}/>
					</div>
				</section>
				<section class="home-credits">


				</section>
				<section class="home-ending">


				</section>
			</main>
		</div>
		<Footer class="home-social"/>
		<Vignette />
	</body>
</html>


<style> 


	/* -------------------------------------------------------------- */ 
	/* ---------------------- MAIN SECTIONS ------------------------- */ 
	/* -------------------------------------------------------------- */ 
	
	.home-container {
		background-image: url('../assets/BG/BG_MainHome_High.jpg');
		background-repeat: no-repeat;
		background-size: cover;
		background-position: top center;
	}

	.home-hero {
		position: relative;
  		min-height: 100vh;
	}

	.home-transition {
		min-height: 40vh;
		width: 100%;
	}

	.home-portfolio {
		position: relative;
		min-height: 100vh;
		width: 100%;
		background-color: rgba(72, 255, 0, 0.13);


		display: flex;
		justify-content: center;
		align-items: center;
	}

	.home-credits {
		min-height: 100vh;
		width: 100%;
	}

	.home-ending {
		min-height: 40vh;
		width: 100%;
	}

	section {
		display: block;
		scroll-snap-align: start;
	}


	body {
		margin: 0;
		padding: 0;
	}

	main {
		width: 100%;
		max-width: 100%;
		margin: 0;
		padding: 0;
	}


	/* -------------------------------------------------------------- */ 
	/* ------------------------ HERO CONFIG ------------------------- */ 
	/* -------------------------------------------------------------- */ 

	.home-backcards img,
	.home-maincard img {
		width: auto;
		height: 100vh;
		max-width: none;
		display: block;
	}

	.home-showreelPlay img {
		width: auto;
		height: 18vh;
	}

	.home-backcards, .home-maincard{
		position: absolute;
		top: 50%;
		left: 50%;
		transform: translate(-50%, -50%) 
					scale(clamp(0.1, 
						min(calc(100vh / 771px), calc(100vw / 300px)), 
						0.70));
		transform-origin: center;
	}

	.home-showreelPlay {
		position: absolute;
		top: 48%;
		left: 50%;
		transform: translate(-50%, -50%);
		transform-origin: center;
		pointer-events: none;
		opacity: 0;
		transition: opacity 0.7s cubic-bezier(0.22, 1, 0.36, 1);
		
	}

	.home-maincard:hover .home-maincard-bg {
		filter: blur(3px) brightness(70%);
		cursor: pointer;
	}


	.home-maincard:hover .home-showreelPlay {
		opacity: 1;
		filter: blur(1px);
		pointer-events: auto;
		cursor: pointer;
	}

	/* ---------------------- Scroll Arrow ----------------------- */ 
	.scroll-arrow {
		/* Transform */ 
		position: absolute;
		bottom: 7%;
		left: 50%;
		z-index: 5;
		
		/* Animation */ 
		--bounce-height: 10px;
		animation: bounce 2s infinite;		
	}




	/* -------------------------------------------------------------- */ 
	/* ---------------------- PORTFOLIO CONFIG ---------------------- */ 
	/* -------------------------------------------------------------- */ 

	.home-softslider-desktop {
		position: absolute;
		top: 7%;
	}

	.home-softslider-phone { display: none; }


	/* -------------------------------------------------------------- */ 
	/* ------------------- PHONE MODIFICATIONS ---------------------- */ 
	/* -------------------------------------------------------------- */ 
	

	@media (max-width: 768px) {
		.home-backcards, .home-maincard {
			top: 46%;
			transform: translate(-50%, -50%) 
						scale(clamp(0.1, 
						min(calc(100vh / 771px), calc(100vw / 300px)), 
						0.55));
		}

		.home-maincard:hover .home-showreelPlay {
			opacity: 0;
		}

		.home-maincard-bg {
			animation: revealBlur 1.5s cubic-bezier(0.22, 1, 0.36, 1) forwards;
			animation-delay: 4s;
		}

		.home-showreelPlay {
			animation: revealOpacity 2s cubic-bezier(0.22, 1, 0.36, 1) forwards;
			animation-delay: 4s;
			top: 45%;
		}

		.scroll-arrow {
			bottom: 18%;
			left: 47%;
		}

		.home-social { display: none; }

		.home-softslider-desktop { display: none; }

		.home-softslider-phone {
			display: flex;
			position: absolute;
			top: 10%;
		}


	}

</style>



<script>
	const arrow = document.querySelector(".scroll-arrow");
	const portfolio = document.querySelector(".home-portfolio");

	arrow?.addEventListener("click", () => {
		portfolio?.scrollIntoView({
		behavior: "smooth",
		block: "start",
		});
	});
</script>