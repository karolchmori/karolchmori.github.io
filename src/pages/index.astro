---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import MainBackCards from '../assets/elements/Main_BackCards.png';
import MainFrontCard from '../assets/elements/Main_FrontCard.png';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<div class="home-container">
					<main>
			<section class="home-hero">
				<a class="home-backcards">
					<img src={MainBackCards.src} alt="" />
				</a>
				<a class="home-maincard">
					<img src={MainFrontCard.src} alt="" />
				</a>
			</section>
			<section class="home-transition">

			</section>
			<section class="home-portfolio">


			</section>
		</main>

		</div>

		<Footer />
	</body>
</html>


<style> 
	.home-container {
		background-image: url('../assets/BG/MainHomeAll_BG_High.jpg');
		background-repeat: no-repeat;
		background-size: cover;
		background-position: top center;
	}


	.home-hero {
		position: relative;
  		min-height: 100vh;
		
	}

	.home-backcards img,
	.home-maincard img {
		width: auto;
		height: 100vh;
		max-width: none;
		display: block;
	}

	.home-backcards, .home-maincard {
		position: absolute;
		top: 50%;
		left: 50%;
		transform: translate(-50%, -50%) scale(clamp(0.1, 100vh / 771px, 0.75));
		transform-origin: center;

	}

	@media (max-width: 768px) {
		.home-backcards, .home-maincard {
			position: absolute;
			top: 47%;
			left: 50%;
			transform: translate(-50%, -50%) scale(clamp(0.1, 100vh / 771px, 0.60));
			transform-origin: center;

		}

	}

	.home-transition {
		min-height: 54vh;
		width: 100%;
	}

	.home-portfolio {
		min-height: 100vh;
		width: 100%;
	}

	section {
		display: block; 
	}


	body {
		margin: 0;
		padding: 0;
	}

	main {
		width: 100%;
		max-width: 100%;
		margin: 0;
		padding: 0;
	}

</style>
