---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import Vignette from '../components/widgets/Vignette.astro';

type Props = CollectionEntry<'tool'>['data'];

const { title, description, pubDate, thumbnail } = Astro.props;
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
	</head>
	<body>
		<Header />
		<div class="tool-container">
			<main>
				<article class="tool-page">
					<div class="hero-image">
						{thumbnail && <Image width={820} height={310} src={thumbnail} alt="" />}
					</div>
					<div class="prose">
						<div class="title">
							<div class="date">
								<FormattedDate date={pubDate} />
							</div>
							<h1>{title}</h1>
							<hr />
						</div>
						<slot /> <!-- Done for Content -->
					</div>
				</article>
			</main>
		</div>
		<Footer />
		<Vignette />
	</body>
</html>


<style>


	html, body {
		margin: 0;
		padding: 0;
		min-height: 100%;
	}

	.tool-container {
		position: relative;
		min-height: 100vh;      /* ← container itself must have a height to push against */
		display: flex;
		flex-direction: column;
	}

	.tool-container::before {
		content: "";
		position: fixed;
		inset: 0;
		background-image: url('../assets/BG/BG_High.jpg');
		background-repeat: no-repeat;
		background-size: cover;
		background-position: top center;
		z-index: -1;
	}

	main {
		position: relative;
		z-index: 1;
		width: calc(100% - 2em);
		max-width: 100%;
		margin: 0 auto;
		flex: 1;                /* ← takes remaining space inside tool-container */
		display: flex;
		flex-direction: column;
	}

	.tool-page {
		background-color: #e8e3e6;
		border-radius: 16px;
		max-width: 900px;
		width: 100%;
		margin: 1.5rem auto;
		overflow: hidden;
		flex: 1;     
		display: flex;
		flex-direction: column;
	}

	.hero-image {
		width: 100%;
	}

	.hero-image img {
		display: block;
		margin: 0 auto;
	}

	.prose {
		width: 720px;
		max-width: calc(100% - 2em);
		margin: auto;
		padding: 1em;
		color: rgb(var(--gray-dark));
	}

	.title {
		margin-bottom: 1em;
		padding: 1em 0;
		text-align: center;
		line-height: 1;
	}

	.title h1 {
		margin: 0 0 0.5em 0;
	}

	.date {
		margin-bottom: 0.5em;
		color: rgb(var(--gray));
	}

	.last-updated-on {
		font-style: italic;
	}

</style>