---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import Vignette from '../components/widgets/Vignette.astro';

type Props = CollectionEntry<'tool'>['data'];

const { title, description, pubDate, thumbnail } = Astro.props;
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
	</head>
	<body>
		<Header />
		<div class="tool-page">
			<main>
				<article class="tool-container">
					<div class="prose">
						<slot /> <!-- Done for Content -->
					</div>
				</article>
			</main>
		</div>
		<Footer />
		<Vignette />
	</body>
</html>


<style>


	html, body {
		margin: 0;
		padding: 0;
		min-height: 100%;
	}

	.tool-page {
		position: relative;
		min-height: 100vh;      /* ← container itself must have a height to push against */
		display: flex;
		flex-direction: column;
	}

	.tool-page::before {
		content: "";
		position: fixed;
		inset: 0;
		background-image: url('../assets/BG/BG_High.jpg');
		background-repeat: no-repeat;
		background-size: cover;
		background-position: top center;
		z-index: -1;
	}

	main {
		position: relative;
		z-index: 1;
		width: calc(100% - 2em);
		max-width: 100%;
		margin: 0 auto;
		flex: 1;                /* ← takes remaining space inside tool-container */
		display: flex;
		flex-direction: column;
	}

	.tool-container {
		background-color: #e8e3e6;
		border-radius: 16px;
		max-width: 900px;
		width: 100%;
		margin: 1.5rem auto;
		overflow: hidden;
		flex: 1;     
		display: flex;
		flex-direction: column;
	}

	.prose {
		width: auto;
		max-width: 85%;
		margin: auto;
		padding: 0.5em;
		color: rgb(var(--gray-dark));
	}


	@media (orientation: portrait), (max-aspect-ratio: 9/16) {
		.tool-container {
			margin: 3rem auto;
		}


	}

</style>