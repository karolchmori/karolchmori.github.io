---
import ArrowButton from './ArrowButton.astro';

interface Props {
    itemsVisible?: number;
    itemSize?: string;
    gap?: number; 
    navigation?: "gradient" | "buttons";
    buttonPosition?: "above" | "below";
    class?: string;
}

const {
    itemsVisible = 4,
    itemSize = "15vh",
    gap = 1,
    navigation = "buttons",
    class: className = "",
} = Astro.props;

const gapPad = gap * 2;
const useButtons = navigation === "buttons";
---

<div class={`carousel-wrapper ${className}`} data-nav={navigation}>
    <div
        class="carousel-track" data-carousel
        style={`--items-visible:${itemsVisible}; --item-size:${itemSize}; --gap:${gap}vw; --gapPad:${gapPad}vh;`}>
        <slot />
    </div>
    {useButtons && (
        <div class="carousel-buttons">
            <div data-carousel-btn="prev"><ArrowButton angle={90} /></div>
            <div data-carousel-btn="next"><ArrowButton angle={-90} /></div>
        </div>
    )}
</div>

<style>
    body {
        overflow-x: hidden;
    }

    .carousel-wrapper {
        position: relative;
        width: calc(var(--items-visible) * var(--item-size) + (var(--items-visible) - 1) * var(--gap));
        max-width: 100%;   
    }

    .carousel-buttons {
        display: flex;
        flex-direction: row;
        justify-content: center;
        padding-top: 1.25em;
        gap: 1.5rem;
    }


    .carousel-track {
        display: flex;
        gap: var(--gap);
        overflow-x: auto;
        overflow-y: hidden;

        scrollbar-width: none;

        cursor: grab;
        user-select: none;

        padding-left: var(--gapPad);
        padding-right: var(--gapPad);
        scroll-padding-left: var(--gapPad);
        scroll-padding-right: var(--gapPad);
        box-sizing: content-box;
    }

    .carousel-track::-webkit-scrollbar {
        display: none;
    }


    .carousel-track.dragging {
        cursor: grabbing;
        scroll-snap-type: none;
        scroll-behavior: auto;
        touch-action: pan-x;
    }
 

    .carousel-track > :global(*) {
        flex: 0 0 var(--item-size);
        width: var(--item-size);
        height: var(--item-size);
        scroll-snap-align: start;
    }

    /* Edge fades */
    .carousel-wrapper::before,
    .carousel-wrapper::after {
        content: "";
        position: absolute;
        top: 0;
        bottom: 0;
        width: 24px;
        pointer-events: none;
        z-index: 2;
        transition: opacity 0.2s ease;
    }


    /* Gradient config */
    [data-nav="gradient"].carousel-wrapper::before {
        left: 0;
        background: linear-gradient(to right, var(--carousel-fade-color, #000000a1), transparent);
        opacity: 0;
    }

    [data-nav="gradient"].carousel-wrapper::after {
        right: 0;
        background: linear-gradient(to left, var(--carousel-fade-color, #000000a1), transparent);
        opacity: 1;
    }

    .carousel-wrapper.at-start::before {
        opacity: 0;
    }

    .carousel-wrapper.at-end::after {
        opacity: 0;
    }

    .carousel-wrapper:not(.at-start)::before {
        opacity: 1;
    }

    .carousel-wrapper:not(.at-end)::after {
        opacity: 1;
    }

    [data-carousel-btn] {
        transition: opacity 0.2s ease, filter 0.2s ease;
    }

    [data-carousel-btn] :global(.scroll-arrow) {
        
        transition: filter 0.2s ease, opacity 0.2s ease;
    }

    .carousel-wrapper.at-start [data-carousel-btn="prev"],
    .carousel-wrapper.at-end [data-carousel-btn="next"] {
        pointer-events: none;
        opacity: 0.3;
        filter: brightness(80%);
    }

    .carousel-wrapper.no-overflow [data-carousel-btn] {
        pointer-events: none;
    }

    .carousel-wrapper.no-overflow [data-carousel-btn] :global(.scroll-arrow){
        opacity: 0;
        transition: opacity 0.2s ease;
    }

    /* Glow states stay the same */
    .carousel-wrapper.at-start [data-carousel-btn="next"] :global(.scroll-arrow), 
    .carousel-wrapper.at-end [data-carousel-btn="prev"] :global(.scroll-arrow) {
        filter: drop-shadow(0 0 10px #ff7ec7);
    }
  
    /* Middle state: reset both to normal */
    .carousel-wrapper:not(.at-start):not(.at-end) [data-carousel-btn="prev"] :global(.scroll-arrow),
    .carousel-wrapper:not(.at-start):not(.at-end) [data-carousel-btn="next"] :global(.scroll-arrow) {
        filter: none;
        opacity: 1;
        transition: opacity 0.2s ease;
    }

  

</style>

<script>
    function initCarousel(track: HTMLElement) {
        const wrapper = track.parentElement as HTMLElement;
        const THRESHOLD = 2; // px tolerance

        function update() {
            const { scrollLeft, scrollWidth, clientWidth } = track;
            const atStart = scrollLeft <= THRESHOLD;
            const atEnd = scrollLeft + clientWidth >= scrollWidth - THRESHOLD;
            const noOverflow = scrollWidth <= clientWidth + THRESHOLD;

            const wasAtStart = wrapper.classList.contains("at-start");
            const wasAtEnd = wrapper.classList.contains("at-end");

            wrapper.classList.toggle("at-start", atStart || noOverflow);
            wrapper.classList.toggle("at-end", atEnd || noOverflow);
            wrapper.classList.toggle("no-overflow", noOverflow);

            if (atEnd && !wasAtEnd) {
                wrapper.dispatchEvent(new CustomEvent("carousel:end", { bubbles: true }));
            }
            if (atStart && !wasAtStart) {
                wrapper.dispatchEvent(new CustomEvent("carousel:start", { bubbles: true }));
            }
        }


        track.addEventListener("scroll", update, { passive: true });
        window.addEventListener("resize", update);

        // Recheck if content/layout changes after initial render
        const ro = new ResizeObserver(update);
        ro.observe(track);

        const mo = new MutationObserver(update);
        mo.observe(track, { childList: true, subtree: true });

        // Initial check
        update();

        // Click-and-drag scrolling for desktop
        let startX = 0;
        let scrollStart = 0;
        let isDragging = false;
 
        track.addEventListener("pointerdown", (e) => {
            isDragging = true;
            
            track.classList.add("dragging");
            startX = e.pageX;
            scrollStart = track.scrollLeft;
        });

        window.addEventListener("pointermove", (e) => {
            if (!isDragging) return; 

            const dx = e.pageX - startX;
            if (Math.abs(dx) > 5) isDragging = true;
            track.scrollLeft = scrollStart - dx;
        });
 
        window.addEventListener("pointerup", () => {
            isDragging = false;
            track.classList.remove("dragging");
        });

        window.addEventListener("pointercancel", () => {
            isDragging = false;
            track.classList.remove("dragging");
        });

        wrapper.querySelector('[data-carousel-btn="prev"]')
            ?.addEventListener("click", () => {
                track.scrollBy({ left: -(track.clientWidth * 0.75), behavior: "smooth" });
            });

        wrapper.querySelector('[data-carousel-btn="next"]')
            ?.addEventListener("click", () => {
                track.scrollBy({ left: track.clientWidth * 0.75, behavior: "smooth" });
            });
 
        
    }

    document.querySelectorAll<HTMLElement>("[data-carousel]").forEach(initCarousel);
</script>