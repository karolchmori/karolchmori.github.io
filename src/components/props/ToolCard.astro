---
// ToolCard.astro
import CardA from '../../assets/icons/AS_CardA.svg';
import CardB from '../../assets/icons/AS_CardB.svg';
import CardFrame from '../../assets/icons/AS_CardFrame.svg';


interface Props {
    filePath?: string;
    software?: string;
    frontmatter?: Record<string, any>;
    index: number;
}

const { filePath, software, frontmatter, index = 0 } = Astro.props;

const title       = frontmatter?.title       ?? "";
const description = frontmatter?.description ?? "";

const initialState = filePath ? "hidden" : "empty";


const cardIcon = index % 2 !== 0 ? CardA : CardB;


---


<div class="tool-card" data-path={filePath} data-software={software} data-state={initialState}>
    <div class="tool-card-empty">
        <img src={cardIcon.src} alt="" />
    </div>
    <div class="tool-card-content">
        <img src={CardFrame.src} alt="" />
        <div class="tool-card-info">
            <h3>{title}</h3>
            <p>{description}</p>
        </div>
  </div>
</div>


<style>



    .tool-card,
    .tool-card-empty,
    .tool-card-content {
        height: 100%;
    }


    .tool-card {
        overflow: visible;
        cursor: pointer;
        transform-style: preserve-3d;
        
    }

    .tool-card-empty {
        display: none;
        align-items: center;
        justify-content: center;
        filter: brightness(80%) opacity(70%);
    }

    .tool-card-content {
        position: relative;
        display: none;
    }


    .tool-card-info {
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        padding: 1rem;
    }

    .tool-card img {
        max-width: 100%;
        max-height: 100%;
        width: auto;
        height: auto;
    }

    /* Visibility status */
    .tool-card[data-state="hidden"] { visibility: hidden; pointer-events: none;}

    .tool-card[data-state="empty"] .tool-card-content { display: none; }
    .tool-card[data-state="empty"] .tool-card-empty   { display: flex; }

    .tool-card[data-state="active"] .tool-card-content { display: flex; }
    .tool-card[data-state="active"] .tool-card-empty   { display: none; }


    .tool-card[data-state="active"] {
        animation: flipIn 1s cubic-bezier(0.22, 1, 0.36, 1) forwards;
        
    }

    .tool-card[data-state="hiding"] {
        animation: flipOut 0.4s cubic-bezier(0.22, 1, 0.36, 1) forwards;
        visibility: visible; /* keep visible during exit animation */
        pointer-events: none;
    }



    @keyframes dealCard {
        from {
            transform: translateY(-20px) rotate(var(--deal-angle, 0deg)) scale(0.8);
            opacity: 0;
        }
        to {
            transform: translateY(0) rotate(0deg) scale(1);
            opacity: 1;
        }
    }


    @keyframes flipIn {
        from {
            transform: translateX(20px) rotateY(-90deg) scale(0.9);
            opacity: 0;
        }
        to {
            transform: translateX(0) rotateY(0deg) scale(1);
            opacity: 1;
        }
    }

</style>