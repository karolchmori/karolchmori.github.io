---
// ToolCard.astro
import CardA from '../../assets/icons/AS_CardA.svg';
import CardB from '../../assets/icons/AS_CardB.svg';
import CardFrame from '../../assets/icons/AS_CardFrame.svg';
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import StackBadge from './StackBadge.astro';


interface Props {
    entry?: CollectionEntry<'tool'>;
    index: number;
}

const { entry, index = 0 } = Astro.props;

const title       = entry?.data.title       ?? "";
const description = entry?.data.description ?? "";
const thumbnail   = entry?.data.thumbnail   ?? null;
const software    = entry?.data.software    ?? "";
const filePath    = entry?.id               ?? null;
const stack       = entry?.data.stack       ?? [];


const initialState = entry ? "hidden" : "empty";


const cardIcon = index % 2 !== 0 ? CardA : CardB;


---


<div class="tool-card" data-path={filePath} data-software={software} data-state={initialState}>
    <div class="tool-card-empty">
        <img src={cardIcon.src} alt="" />
    </div>
    <div class="tool-card-content">
        <img src={CardFrame.src} alt="" />
        <div class="tool-card-information">
            <div class="tool-card-thumbnail">
                {thumbnail 
                    ? <Image src={thumbnail} alt={title}/>
                    : <div class="tool-card-thumbnail-empty" />
                }
            </div>
            <div class="tool-card-description">
                <h4>{title}</h4>
                <p>{description}</p>
                <div class="tool-card-stack">
                    {stack.map(tech => <StackBadge name={tech} />)}
                </div>
            </div>
        </div>

  </div>
</div>


<style>



    .tool-card,
    .tool-card-empty,
    .tool-card-content {
        height: 100%;
    }

    .tool-card img {
        max-width: 100%;
        max-height: 100%;
        width: auto;
        height: auto;
        

    }

    .tool-card {
        overflow: visible;
        cursor: pointer;
        transform-style: preserve-3d;
        border-radius: 14px;
        filter: drop-shadow(0px 2px 4px rgba(13, 12, 13, 0.669));
        
    }

    .tool-card-empty {
        display: none;
        align-items: center;
        justify-content: center;
        filter: brightness(70%) opacity(60%);
    }

    .tool-card-content {
        position: relative;
        display: none;
        
    }

    .tool-card-information {
        position: absolute;   /* ← add this */
        inset: 0;             /* ← fill the card */
        display: flex;
        flex-direction: column;
        z-index: 1;           /* ← sit above the CardFrame img */
        overflow: hidden;
        border-radius: 14px;
    }

    .tool-card-thumbnail {
        width: 100%;
        flex: 0 0 55%;   
        overflow: hidden;
    }

    .tool-card-thumbnail img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
    }


    .tool-card-description {
        flex: 1;
        padding: 1rem;
    
    }

    .tool-card-stack {
        display: flex;
        flex-direction: row;
        align-items: center;
    }


    /* Visibility status */
    .tool-card[data-state="hidden"] { visibility: hidden; pointer-events: none;}

    .tool-card[data-state="empty"] .tool-card-content { display: none; }
    .tool-card[data-state="empty"] .tool-card-empty   { display: flex; }

    .tool-card[data-state="active"] .tool-card-content { display: flex; }
    .tool-card[data-state="active"] .tool-card-empty   { display: none; }


    .tool-card[data-state="active"] {
        animation: flipIn 1.5s cubic-bezier(0.22, 1, 0.36, 1) forwards;
        
    }


    @keyframes dealCard {
        0% {
            opacity: 0;
        }
        20% {
            transform: translateY(-20px) rotate(var(--deal-angle, 0deg)) scale(0.8);
            opacity: 0;
        }
        100% {
            transform: translateY(0) rotate(0deg) scale(1);
            opacity: 1;
        }
    }


    @keyframes flipIn {
        from {
            transform: translateX(20px) rotateY(-90deg) scale(0.9);
            opacity: 0;
        }
        to {
            transform: translateX(0) rotateY(0deg) scale(1);
            opacity: 1;
        }
    }

    @keyframes fadeOut {
        from {
            opacity: 1;
            transform: rotateY(0deg) scale(1);
        }
        to {
            opacity: 0;
            transform: rotateY(-90deg) scale(0.9);
        }
    }

</style>