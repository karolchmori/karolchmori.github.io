---
import type { SoftwareTool } from '../../objects/SoftwareTool';
import "../../styles/global.css";


// Define the expected props for the component
interface Props {
    tool: SoftwareTool;
}

const { tool } = Astro.props;

---

<div class="software-chip" data-path={tool.pagesPath}>
    <div class="icon-wrapper">
        <img src={tool.iconPath} alt="" />
    </div>
</div>



<style>

    .software-chip {
        cursor: inherit;
        width: 100%;
        height: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        user-select: none;
    }

    .icon-wrapper {
        width: 100%;
        height: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .software-chip img {
		max-width: 70%;
        max-height: 70%;
        width: auto;
        height: auto;
        transition: filter 0.3s ease;
        filter: brightness(0.7);
	}


    /* Chip states */
    .software-chip.pulse img {
        animation: chip-pulse 2s ease-in-out infinite;
    }


    .software-chip.selected img {
        filter: drop-shadow(0 0 6px var(--color-primary-glow)) brightness(1.2);
    }


    .software-chip.selected .icon-wrapper {
        transform: translateY(-3px) scale(1.05);
        transition: transform 0.2s ease;
    }
    

    @media (hover: hover) and (pointer: fine) {
        .software-chip:hover .icon-wrapper {
            transform: translateY(-3px) scale(1.05);
        }

        .software-chip.selected:hover  {
            transform: none;
        }
    }
    

    @keyframes chip-pulse {
        0%, 100% {
            filter: brightness(0.7) drop-shadow(0 0 2px var(--color-primary-glow));
        }
        50% {
            filter: brightness(1.1) drop-shadow(0 0 7px var(--color-primary-glow));
        }
    }

    @media (prefers-reduced-motion: reduce) {
        .software-chip.pulse img {
            animation: none;
        }
    }


</style>

<script>
    document.querySelectorAll<HTMLElement>('.software-chip').forEach((chip, index) => {
        let startX = 0;
        let startY = 0;
        let moved = false;

        if (index === 0 && !document.querySelector('.software-chip.selected')) {
        chip.classList.add('pulse');
        }

        chip.addEventListener('pointerdown', (e) => {
            startX = e.clientX;
            startY = e.clientY;
            moved = false;
        });

        chip.addEventListener('pointermove', (e) => {
            if (Math.abs(e.clientX - startX) > 5 || Math.abs(e.clientY - startY) > 5) {
                moved = true;
            }
        });

        chip.addEventListener('click', () => {
            if (moved) return;

            clearSelection();
            selectChip(chip);

            const path = chip.dataset.path;
            window.dispatchEvent(new CustomEvent('tool:selected', { detail: { path } }));
        });
    });

    function clearSelection() {
        document.querySelectorAll('.software-chip.selected, .software-chip.pulse')
            .forEach(c => c.classList.remove('selected', 'pulse'));
    }

    function selectChip(chip: HTMLElement) {
        chip.classList.add('selected');
    }




</script>