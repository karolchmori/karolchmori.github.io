---
import type { SoftwareTool } from '../../objects/SoftwareTool';


// Define the expected props for the component
interface Props {
    tool: SoftwareTool;
}

const { tool } = Astro.props;

---

<div class="software-chip" data-path={tool.pagesPath}>
    <div class="icon-wrapper">
        <img src={tool.iconPath} alt="" />
    </div>
</div>


<style>
    .software-chip img {
		max-width: 90%;
        max-height: 90%;
        width: auto;
        height: auto;
	}
    
    .software-chip {
        cursor: pointer;
        width: 190%;
        height: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .software-chip:hover {
        transform: translateY(2px) scale(1.05);
    }

    .icon-wrapper {
        width: 100%;
        height: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
    }


</style>