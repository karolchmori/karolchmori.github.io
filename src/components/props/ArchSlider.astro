---
// ArchSlider.astro

export interface Props {
    widthRes?: number;
    heightRes?: number;
    cards?: string[];

}

const {widthRes = 70, heightRes = 20} = Astro.props;

const cards = [
  "Text1",
  "Text2",
  "Text3",
  "Text4",
  "Text5"
];

---
<div class="slider-container" style={`--widthRes: ${widthRes}vw; --heightRes: ${heightRes}vh;`}>
    <div class="slider-viewport" >
        <div class="slider-wrapper" id="wrapper">
            <div class="slider-circle">
                {cards.map((card, i) => (
                    <a class="handle" style={`--i:${i}; --total:15;`}>
                        <span class="handle-content">
                            {card}
                        </span>
                        
                    </a>
                ))}
            </div>
        </div>
    </div>
</div>


<style>

    .slider-container {
        width: var(--widthRes);
        border: 10px solid purple;
        background-color: transparent;
    }

    .slider-viewport {
        position: relative;
        overflow: visible; /* Later hidden */
        width: 100%;
        height: var(--heightRes);
        
        background-color: red;

        /* Center objects */
        display: flex;
        justify-content: center;

    }

    .slider-wrapper {
        --circle-size: 30vw;
        width: var(--circle-size);
        height: var(--circle-size);

        transform-origin: center center;

        background-color: rgba(0, 0, 255, 0.528);
    }

    .slider-circle {
        /* Circle Definition */
        position: relative;
        width: 100%;
        height: 100%;
        border-radius: 50%;

        /* Circle position */
        --start-angle: -130deg;
        --step: calc(360deg / var(--total)); 
        transform: rotate(var(--start-angle));
        

        /* Remove the solid background color */
        background-color: rgba(128, 128, 128, 0.598);
        border-top: 4px solid #e0e0e0; 
    }

    .handle {
        background-color: white;

        /* Position Definition */
        position: absolute;
        top: 50%;
        left: 50%;

        transform:
            rotate(calc(var(--i) * 360deg / var(--total)))
            translate(calc(var(--circle-size)/2.8));

        transform-origin: center;
    }

    .handle-content {
        display: block;
        cursor: grab;
        user-select: none;
        touch-action: none;
        background-color: red;

        /*transform: rotate(calc( -1 * var(--start-angle) - (var(--i) * 360deg / var(--total)))); */

        transform: rotate(90deg);

        transform-origin: center;
        
    }


    .handle:active {
        cursor: grabbing;
    }

</style>


<script>
    const wrapper = document.getElementById("wrapper");
    const handles = document.querySelectorAll<HTMLElement>(".handle");

    /* Rotation definition */
    let baseRotation = 0;
    let isDragging = false;
    let maxAngle = 20;
    let minAngle = -70;
    let lastAngle = 0;
        

    if (handles && wrapper) {

        handles.forEach((handle) => {
            attatchEvents(handle, wrapper);

        });
    

    }


    /* --------------- Rotation Functions --------------- */

    function getAngle(e: PointerEvent, centerX: number, centerY: number) {
        return Math.atan2(e.clientY - centerY, e.clientX - centerX);
    }

    function getCenter(el: HTMLElement) {
        const rect = el.getBoundingClientRect();
        return {
            x: rect.left + rect.width / 2,
            y: rect.top + rect.height / 2
        };
    }

    function attatchEvents(handle: HTMLElement, wrapper: HTMLElement){

        handle.addEventListener("pointerdown", (e) => {
            isDragging = true;
            handle.setPointerCapture(e.pointerId);
            const center = getCenter(wrapper);

            lastAngle = getAngle(e, center.x, center.y);
        });

        handle.addEventListener("pointermove", (e) => {
            if (!isDragging) return;

            const center = getCenter(wrapper);
            const currentAngle = getAngle(e, center.x, center.y);
            let delta = currentAngle - lastAngle;
            if (delta > Math.PI) delta -= 2 * Math.PI;
            if (delta < -Math.PI) delta += 2 * Math.PI;

            lastAngle = currentAngle;

            let rotationDeg = baseRotation + delta * (180 / Math.PI);

            // clamp result only
            if (rotationDeg > maxAngle) rotationDeg = maxAngle;
            if (rotationDeg < minAngle) rotationDeg = minAngle;
            
            baseRotation = rotationDeg;

            wrapper.style.transform = `rotate(${rotationDeg}deg)`;
        });

        handle.addEventListener("pointerup", () => {
            isDragging = false;
        });

        handle.addEventListener("pointercancel", () => {
            isDragging = false;
        });
    }

</script>