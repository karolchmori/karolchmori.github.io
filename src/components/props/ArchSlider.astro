---
// ArchSlider.astro


// 1. Define the TypeScript interface for our props
export interface Props {
    widthRes?: number;
    heightRes?: number;
    cards?: string[];

}

const {widthRes = 70, heightRes = 20, cards = null} = Astro.props;
---
<div class="slider-container" style={`--widthRes: ${widthRes}vw; --heightRes: ${heightRes}vh;`}>
    <div class="slider-viewport" >
        <div class="slider-wrapper" id="wrapper">
            <div class="slider-circle">
                <a id="handle">Text</a>
            </div>
        </div>
    </div>
</div>


<style>

    .slider-container {
        width: var(--widthRes);
        border: 10px solid purple;
        background-color: transparent;
    }

    .slider-viewport {
        position: relative;
        overflow: visible; /* Later hidden */
        width: 100%;
        height: var(--heightRes);
        
        background-color: red;

        /* Center objects */
        display: flex;
        justify-content: center;

    }

    .slider-wrapper {
        --circle-size: 30vw;
        width: var(--circle-size);
        height: var(--circle-size);

        transform-origin: center center;

        background-color: rgba(0, 0, 255, 0.528);
    }

    .slider-circle {
        width: 100%;
        height: 100%;
        border-radius: 50%;

        /* Remove the solid background color */
        background-color: rgba(128, 128, 128, 0.598);
        border-top: 4px solid #e0e0e0; 
    }

    #handle {
        cursor: grab;
        user-select: none;
        touch-action: none;
    }

    #handle:active {
        cursor: grabbing;
    }

</style>


<script>
    const wrapper = document.getElementById("wrapper");
    const handle = document.getElementById("handle");

    let isDragging = false;
    let angle = 0;
    let startX = 0;

    if (handle && wrapper) {
        handle.addEventListener("pointerdown", (e) => {
            isDragging = true;
            startX = e.clientX;
            handle.setPointerCapture(e.pointerId);
        });

        handle.addEventListener("pointermove", (e) => {
            if (!isDragging) return;

            const deltaX = e.clientX - startX;

            angle += deltaX * 0.5; // rotation sensitivity

            wrapper.style.transform = `rotate(${angle}deg)`;

            startX = e.clientX;
        });

        handle.addEventListener("pointerup", () => {
            isDragging = false;
        });

        handle.addEventListener("pointercancel", () => {
            isDragging = false;
        });
    }

</script>