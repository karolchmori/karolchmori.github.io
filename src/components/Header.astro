---
import Logo from './Logo.astro';
import HeaderLink from './HeaderLink.astro';

---
<header>
	
	<nav>
		<Logo />
		<button class="hamburger" aria-label="Menu">☰</button>
		<div class="navigator-pages">
			<HeaderLink href="/about">About</HeaderLink>
			<HeaderLink href="/work">Work</HeaderLink>
			<HeaderLink href="/blog">Blog</HeaderLink>
		</div>
	</nav>
</header>
<style>
	header {
		position: fixed; /* Keeps it locked to the screen while scrolling */
		top: 0;
		width: 100%;
		height: 100%;
		z-index: 1000; /* Ensures it stays on top of the background */
		background-image: url('../assets/BG/Desktop_TopMenu_BG.png');
		background-size: cover;
		background-position: center;
		background-blend-mode: multiply;
		opacity: 0.8;
	}

	nav {
		display: flex;
		align-items: top;
		justify-content: space-between;
	}

	.hamburger { display: none; }

	@media (max-width: 768px) {
		header {
			background-image: url('../assets/BG/Phone_TopMenu_BG.png');
			background-position: 5% 5%;
			background-repeat: no-repeat;
			background-size: auto;
		}


		.hamburger { 
			display: block;
			background: none;
			color: white;
			border: none;
			font-size: 30px;
		
		}
		.navigator-pages { display: none; flex-direction: column; position: absolute; top: 60px; right: 0; }
		.navigator-pages.open { display: flex; }
		
	}

	


</style>


<script>
  	window.addEventListener('scroll', () => {
		const header = document.querySelector('header');
		if (header){
			if (window.scrollY > 50) {
				header.classList.add('scrolled');
			} else {
				header.classList.remove('scrolled');
			}
		}
  	});
</script>