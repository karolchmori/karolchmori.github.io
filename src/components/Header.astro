---
import Logo from './Logo.astro';
import HeaderLink from './HeaderLink.astro';

---
<header>
	
	<nav>
		<Logo />
		<div class="navigator-pages">
			<HeaderLink href="/about">About</HeaderLink>
			<HeaderLink href="/work">Work</HeaderLink>
			<HeaderLink href="/blog">Blog</HeaderLink>
		</div>
	</nav>
</header>
<style>
	header {
		position: fixed; /* Keeps it locked to the screen while scrolling */
		top: 0;
		width: 100%;
		height: 100%;
		z-index: 1000; /* Ensures it stays on top of the background */
		background-image: url('../assets/BG/TopMenu_BG.png');
		background-size: cover;
		background-position: center;
		background-blend-mode: multiply;
		opacity: 0.8;
	}
	nav {
		display: flex;
		align-items: top;
		justify-content: space-between;
	}
</style>


<script>
  	window.addEventListener('scroll', () => {
		const header = document.querySelector('header');
		if (header){
			if (window.scrollY > 50) {
				header.classList.add('scrolled');
			} else {
				header.classList.remove('scrolled');
			}
		}
  	});
</script>