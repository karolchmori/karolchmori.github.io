---
import SocialLinks from '../components/SocialLinks.astro';
---

<footer>
	<div class="footer-social">
		<SocialLinks orientation="horizontal"/>
	</div>
</footer>


<style>
	footer {
		bottom: 0;
		right: 0;
		width: 100%;
		position: fixed;
		z-index: 1000;
		background: transparent;
		text-align: center;

		padding-bottom: calc(0.5em + env(safe-area-inset-bottom));
		padding-top: 1em;
		padding-left: 1em;
		padding-right: 1em;
	}

	@media (max-width: 768px) {

		.footer-social {
			display: none;
		}
	}

</style>
