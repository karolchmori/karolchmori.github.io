---
interface Props {
  opacity?: number;
}

const { opacity = 0.8 } = Astro.props;
---

<div class="vignette" style={`--vignette-opacity: ${opacity};`} />

<style>
  .vignette {
    position: fixed;
    inset: 0;
    pointer-events: none;

    background: radial-gradient(
      ellipse 200% 70% at 50% 58%,
      transparent 0%,
      transparent 70%,
      rgba(66, 12, 48, 0) 55%,
      rgba(12, 9, 12, 0.85) 80%,
      rgba(0, 0, 0, 0.912) 100%
    );

    opacity: var(--vignette-opacity);
    z-index: 50;
  }
</style>