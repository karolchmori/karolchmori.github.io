---
import ArrowButton from '../widgets/ArrowButton.astro';

interface Props {
    itemSize?: string;
    gap?: number; 
    navigation?: "gradient" | "buttons";
    buttonPosition?: "top" | "bottom";
    buttonJustify?: "left" | "center" | "right";
    class?: string;
}

const {
    itemSize = "18vh",
    gap = 0.5,
    navigation = "gradient",
    buttonPosition = "bottom",
    buttonJustify = "center",
    class: className = ""
} = Astro.props;

const useButtons = navigation === "buttons";
---

<div class={`carousel-wrapper ${className}`} data-nav={navigation} data-btn-pos={buttonPosition}
    style={`--item-size:${itemSize}; --gap:${gap}vh; --buttonJustify:${buttonJustify};`}>
    <div class="carousel-track" data-carousel>
        <slot />
    </div>
    {useButtons && (
        <div class="carousel-buttons">
            <div data-carousel-btn="prev"><ArrowButton heightVh = {1.5} angle={90} /></div>
            <div data-carousel-btn="next"><ArrowButton heightVh = {1.5} angle={-90} /></div>
        </div>
    )}
</div>

<style>
    body {
        overflow-x: hidden;
    }

    .carousel-track,
    [data-carousel-btn],
    .scroll-arrow,
    .software-chip {
        -webkit-tap-highlight-color: transparent;
        -webkit-user-drag: none;
        -webkit-touch-callout: none;
        -webkit-user-select: none;
    }
    

    .carousel-wrapper{
        position: relative;
        width: 100%;
        display: flex;
        flex-direction: column; 
    }

    .carousel-track {
        justify-content: flex-start;
    }

    .carousel-wrapper.no-overflow .carousel-track {
        justify-content: center;
    }


    .carousel-track {
        display: flex;
        gap: var(--gap);
        overflow-x: auto;
        overflow-y: hidden;

        scrollbar-width: none;

        /* User */
        cursor: pointer;
        user-select: none;

        /* Side Padding */
        --gapPad: 1.5em;

        padding-left: var(--gapPad);
        padding-right: var(--gapPad);
        scroll-padding-left: var(--gapPad);
        scroll-padding-right: var(--gapPad);
    }

    .carousel-track::-webkit-scrollbar {
        display: none;
    }


    .carousel-track.dragging {
        cursor: grabbing;
        scroll-snap-type: none;
        scroll-behavior: auto;
        touch-action: pan-x;
    }

    /* Carousel Children */
    .carousel-track > :global(*) {
        flex: 0 0 var(--item-size);
        scroll-snap-align: start;
    }
 
    .carousel-buttons {
        display: flex;
        flex-direction: row;
        justify-content: var(--buttonJustify);
        padding: 0.5em;
        gap: 0.5rem;
    }

    :global([data-btn-pos="top"] .carousel-buttons) {
        order: -1;  /* moves buttons before the track */
        padding-top: 0;
        padding-bottom: 0.5em;
    }


    /* Edge fades */
    .carousel-wrapper::before,
    .carousel-wrapper::after {
        content: "";
        position: absolute;
        top: 0;
        bottom: 0;
        width: 20px;
        pointer-events: none;
        z-index: 2;
        transition: opacity 0.2s ease;
    }


    /* Gradient config */
    [data-nav="gradient"].carousel-wrapper::before {
        left: 0;
        background: linear-gradient(to right, var(--color-primary-fade), transparent);
        opacity: 0;
    }

    [data-nav="gradient"].carousel-wrapper::after {
        right: 0;
        background: linear-gradient(to left, var(--color-primary-fade), transparent);
        opacity: 1;
    }

    .carousel-wrapper.at-start::before {
        opacity: 0;
    }

    .carousel-wrapper.at-end::after {
        opacity: 0;
    }

    .carousel-wrapper:not(.at-start)::before {
        opacity: 1;
    }

    .carousel-wrapper:not(.at-end)::after {
        opacity: 1;
    }




</style>

<script>
    function initCarousel(track: HTMLElement) {
        const wrapper = track.parentElement as HTMLElement;
        wrapper.style.opacity = '0';
        const THRESHOLD = 2; // px tolerance

        const prevBtn = wrapper.querySelector<HTMLElement>('[data-carousel-btn="prev"]');
        const nextBtn = wrapper.querySelector<HTMLElement>('[data-carousel-btn="next"]');
        

        function setArrowState(btn: HTMLElement | null, state: 'enabled' | 'glow' | 'disabled' | 'hidden') {
            if (!btn) return;
            const arrow = btn.querySelector<HTMLElement>('.arrow-btn');
            arrow?.classList.remove('enabled', 'glow', 'disabled', 'hidden');
            arrow?.classList.add(state);
            btn.style.pointerEvents = (state === 'disabled' || state === 'hidden') ? 'none' : '';
        }

        function update() {
            const { scrollLeft, scrollWidth, clientWidth } = track;
            const atStart = scrollLeft <= THRESHOLD;
            const atEnd = scrollLeft + clientWidth >= scrollWidth - THRESHOLD;
            const noOverflow = scrollWidth <= clientWidth + THRESHOLD;

            const wasAtStart = wrapper.classList.contains("at-start");
            const wasAtEnd = wrapper.classList.contains("at-end");
            wrapper.classList.toggle("at-start", atStart);
            wrapper.classList.toggle("at-end", atEnd);
            wrapper.classList.toggle("no-overflow", noOverflow);

            wrapper.style.opacity = '';


            if (noOverflow) {
                setArrowState(prevBtn, 'hidden');
                setArrowState(nextBtn, 'hidden');
            } else if (atStart) {
                setArrowState(prevBtn, 'disabled');
                setArrowState(nextBtn, 'glow');
            } else if (atEnd) {
                setArrowState(prevBtn, 'glow');
                setArrowState(nextBtn, 'disabled');
            } else {
                setArrowState(prevBtn, 'enabled');
                setArrowState(nextBtn, 'enabled');
            }

            if (atEnd && !wasAtEnd) {
                wrapper.dispatchEvent(new CustomEvent("carousel:end", { bubbles: true }));
            }
            if (atStart && !wasAtStart) {
                wrapper.dispatchEvent(new CustomEvent("carousel:start", { bubbles: true }));
            }
        }


        track.addEventListener("scroll", update, { passive: true });
        window.addEventListener("resize", update);

        // Recheck if content/layout changes after initial render
        /*
        const ro = new ResizeObserver(update);
        

        const mo = new MutationObserver(update);
        mo.observe(track, { childList: true, subtree: true });
        */
        const ro = new ResizeObserver(() => {
            requestAnimationFrame(() => requestAnimationFrame(update));
        });
        ro.observe(track);


        const mo = new MutationObserver(() => {
            requestAnimationFrame(() => requestAnimationFrame(update));
        });
        mo.observe(track, { childList: true, subtree: true });

        // Initial check
        track.scrollLeft = 0;
        update();

        // Click-and-drag scrolling for desktop
        let startX = 0;
        let scrollStart = 0;
        let isDragging = false;
 
        track.addEventListener("pointerdown", (e) => {
            isDragging = true;
            
            track.classList.add("dragging");
            startX = e.pageX;
            scrollStart = track.scrollLeft;
        });

        window.addEventListener("pointermove", (e) => {
            if (!isDragging) return; 

            const dx = e.pageX - startX;
            if (Math.abs(dx) > 5) isDragging = true;
            track.scrollLeft = scrollStart - dx;
        });
 
        window.addEventListener("pointerup", () => {
            isDragging = false;
            track.classList.remove("dragging");
        });

        window.addEventListener("pointercancel", () => {
            isDragging = false;
            track.classList.remove("dragging");
        });

        wrapper.querySelector('[data-carousel-btn="prev"]')
            ?.addEventListener("click", () => {
                track.scrollBy({ left: -(track.clientWidth * 0.7), behavior: "smooth" });
            });

        wrapper.querySelector('[data-carousel-btn="next"]')
            ?.addEventListener("click", () => {
                track.scrollBy({ left: track.clientWidth * 0.7, behavior: "smooth" });
            });
 
        
    }

    document.querySelectorAll<HTMLElement>("[data-carousel]").forEach(initCarousel);
</script>