---
// VideoModal.astro
import { getVideoUrl } from "../../lib/video";


interface Props {
	trigger: string;
	platform: "vimeo" | "youtube";
    idVideo: string;
	viewPercent?: number;
	autoplay?: number;
}

const { trigger, platform, idVideo, viewPercent = 80, autoplay = 1} = Astro.props;

const src = getVideoUrl(platform, idVideo, autoplay);

---

<div class="video-overlay" data-modal>
	<div class="video-container" style={`--viewPer: ${viewPercent/100}`}>
		<iframe
			data-src={src}
			frameborder="0"
			allow="autoplay; fullscreen; picture-in-picture"
		/>
	</div>
</div>

<style>

    .video-overlay {
		position: fixed;
		inset: 0;
		align-items: center;
		justify-content: center;
		background: rgba(0, 0, 0, 0.8);
		z-index: 9999;

		/* Prevents affecting other layouts when is hidden */
		visibility: hidden;
		opacity: 0;
		pointer-events: none;
		transition: opacity 0.2s ease;
	}

	.video-overlay.is-open {
		display: flex !important;
		visibility: visible;
		opacity: 1;
		pointer-events: auto;
	}

	.video-container {
		width: min(calc(var(--viewPer) * 100vw), calc(var(--viewPer) * 100vh * 16 / 9));
		aspect-ratio: 16 / 9;
		position: relative;
	}

	.video-container iframe {
		width: 100%;
		height: 100%;
		border: 0;
	}

</style>

<script define:vars={{ trigger, src }}>
	const button = document.querySelector(trigger);
	const overlay = document.querySelector("[data-modal]");
	const iframe = overlay.querySelector("iframe");

	function open() {
		iframe.src = src;
		overlay?.classList.add("is-open");
		document.body.classList.add("no-scroll");
	}

	function close() {
		iframe.src = "";
		overlay?.classList.remove("is-open");
		document.body.classList.remove("no-scroll");
	}

	button?.addEventListener("click", open);

	overlay?.addEventListener("click", (e) => {
		if (e.target === overlay) close();
	});

	document.addEventListener("keydown", (e) => {
		if (e.key === "Escape") close();
	});
    
</script>