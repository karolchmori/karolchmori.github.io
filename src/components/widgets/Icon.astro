---
/**
 * Icon.astro
 * Renders a hand-picked SVG icon by name.
 *
 * Usage:
 * <Icon name="chevron-up-down" />
 * <Icon name="chevron-left-right" size={20} stroke-width={1.5} class="text-red-500" />
 *
 */

const ICONS = {
    'chevron-up-down': 'M7 9l5-5 5 5M7 15l5 5 5-5',                // USED
    'chevron-left-right': 'M15 7l5 5-5 5M9 7l-5 5 5 5',            // USED
    'chevron-down': 'M6 9l6 6 6-6',                                // USED
    'chevron-up': 'M18 15l-6-6-6 6',                               // USED
    'chevron-left': 'M9 6l6 6-6 6',                                // USED
    'close': 'M6 6l12 12M18 6L6 18',
    'check': 'M5 13l4 4L19 7',                                     // USED
    'copy': 'M9 9h10v10H9zM5 15V5h10',                             // USED
    'arrow-right': 'M5 12h14M13 6l6 6-6 6',
    'note' : 'M7 2.5h7l4 4V20a1.5 1.5 0 0 1-1.5 1.5h-9A1.5 1.5 0 0 1 6 20V4A1.5 1.5 0 0 1 7 2.5Zm7 0V6a1 1 0 0 0 1 1h3.5',   // USED
    'info' : 'M12 2a10 10 0 1 0 0 20 10 10 0 0 0 0-20Zm0 5a1 1 0 1 1 0 2 1 1 0 0 1 0-2Zm1 11h-2v-7h2v7Z',           // USED
    'tip' : 'M9 18h6M10 22h4M12 2a6 6 0 0 0-4 10.47c.39.34.6.83.6 1.34V15h6.8v-1.19c0-.51.21-1 .6-1.34A6 6 0 0 0 12 2Z',      // USED
    'warning' : 'M12 9v4m0 4h.01M10.29 3.86 1.82 18a1.5 1.5 0 0 0 1.29 2.25h17.78A1.5 1.5 0 0 0 22.18 18L13.71 3.86a1.5 1.5 0 0 0-2.62 0Z',     // USED
    'danger' : 'M12 2 1 21h22L12 2Zm0 7v6m0 3h.01',                 // USED
    'cross' : 'M6 6l12 12M18 6L6 18',                               // USED
    'circle' : 'M12 2a10 10 0 1 0 0 20 10 10 0 0 0 0-20Z',          // USED
    'star' : 'M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2Z', // USED
    'arrow' : 'M5 12h14M13 6l6 6-6 6',                              // USED
    'empty-dot' : 'M12 12m-3 0a3 3 0 1 0 8 0 3 3 0 1 0-8 0', 
    'dot' : 'M12 12m-3 0a3 3 0 1 0 8 0 3 3 0 1 0-8 0',              // USED
} as const;

export type IconName = keyof typeof ICONS;

const FILLED_ICONS = new Set<IconName>(['dot']);

interface Props {
    name: IconName;
    size?: number;
    strokeWidth?: number;
    class?: string;
}

const { name, size = 14, strokeWidth = 2, class: className } = Astro.props;

const path = ICONS[name];

if (!path) {
    throw new Error( `Icon: unknown icon name "${name}".`);
}

const isFilled = FILLED_ICONS.has(name);
---

<svg width={size} height={size} viewBox="0 0 24 24" fill="none" aria-hidden="true" class={className}>
    <path
        d={path}
        fill={isFilled ? 'currentColor' : 'none'}
        stroke={isFilled ? 'none' : 'currentColor'}
        stroke-width={strokeWidth}
        stroke-linecap="round"
        stroke-linejoin="round"
    />
</svg>