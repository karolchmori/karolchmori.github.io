---
/**
 * Icon.astro
 * Renders a hand-picked SVG icon by name.
 *
 * Usage:
 * <Icon name="chevron-up-down" />
 * <Icon name="chevron-left-right" size={20} stroke-width={1.5} class="text-red-500" />
 *
 * To add a new icon: drop its path data into the ICONS map below.
 * Keep every icon on the same 24x24 viewBox so sizing stays consistent.
 */

const ICONS = {
    'chevron-up-down': 'M7 9l5-5 5 5M7 15l5 5 5-5',
    'chevron-left-right': 'M15 7l5 5-5 5M9 7l-5 5 5 5',
    'chevron-down': 'M6 9l6 6 6-6',
    'chevron-up': 'M18 15l-6-6-6 6',
    'chevron-left': 'M9 6l6 6-6 6',
    'close': 'M6 6l12 12M18 6L6 18',
    'check': 'M5 13l4 4L19 7',
    'copy': 'M9 9h10v10H9zM5 15V5h10',
    'arrow-right': 'M5 12h14M13 6l6 6-6 6',
} as const;

export type IconName = keyof typeof ICONS;

interface Props {
    name: IconName;
    size?: number;
    strokeWidth?: number;
    class?: string;
}

const { name, size = 14, strokeWidth = 2, class: className } = Astro.props;

const path = ICONS[name];

if (!path) {
    throw new Error( `Icon: unknown icon name "${name}".`);
}
---

<svg width={size} height={size} viewBox="0 0 24 24" fill="none" aria-hidden="true" class={className}>
    <path d={path} stroke="currentColor" stroke-width={strokeWidth} stroke-linecap="round" stroke-linejoin="round"/>
</svg>