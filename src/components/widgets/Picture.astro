---
import { Image } from 'astro:assets';
import { resolveImage, type ImageSource } from '../../lib/image';

interface Props {
    src: ImageSource;
    alt?: string;
    loading?: 'eager' | 'lazy';
    draggable?: boolean;
    clickOn?: boolean;
    class?: string;
    allowCaption?: boolean;
    positionCaption?: 'left' | 'center' | 'right';
}

const { src, alt = '', loading = 'lazy', draggable, class: className, clickOn = false, allowCaption = false,
  positionCaption = 'left' } = Astro.props;

const resolved = resolveImage(src, 'src');
const isLocal = typeof resolved !== 'string';
const showCaption = allowCaption && alt;
---
{clickOn ? (
    <button type="button" class="picture-trigger" data-click-modal="true" aria-label={alt ? `Open image: ${alt}` : 'Open image'} >
        {isLocal ? (
            <Image src={resolved as ImageMetadata} alt={alt} draggable={draggable} class={className} />
        ) : (
            <img src={resolved as string} alt={alt} loading={loading} draggable={draggable} class={className} />
        )}
     </button>
) : (
    isLocal ? (
        <Image src={resolved as ImageMetadata} alt={alt} draggable={draggable} class={className} />
    ) : (
        <img src={resolved as string} alt={alt} loading={loading} draggable={draggable} class={className} />
    )
)}
{showCaption && (
      <figcaption class="picture-caption" data-align={positionCaption}>{alt}</figcaption>
)}

<style>
    .picture-trigger {
        all: unset;
        display: inline-block;
        line-height: 0;
        cursor: pointer;
    }

    .picture-trigger img {
        cursor: pointer;
    }

    .picture-trigger:focus-visible {
        outline: 2px solid currentColor;
        outline-offset: 2px;
    }

    .picture-caption {
        font-size: 0.8rem;
        line-height: 1.4;
        color: var(--text-secondary, currentColor);
        font-family: ui-monospace, 'SFMono-Regular', Menlo, monospace;
    }

    .picture-caption[data-align="left"] {
        text-align: left;
    }

    .picture-caption[data-align="center"] {
        text-align: center;
    }

    .picture-caption[data-align="right"] {
        text-align: right;
    }
</style>


<style is:global>
    .picture-modal-overlay {
        position: fixed;
        inset: 0;
        z-index: 1000;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 2rem;
        background: rgba(0, 0, 0, 0.85);
        cursor: zoom-out;
        animation: picture-modal-fade 0.15s ease-out;
    }

    .picture-modal-image {
        max-width: 100%;
        max-height: 100%;
        object-fit: contain;
        cursor: default;
    }

    @keyframes picture-modal-fade {
        from { opacity: 0; }
        to { opacity: 1; }
    }

</style>

<script>

    if (!(window as any).__pictureModalInit) {
        (window as any).__pictureModalInit = true;

        let overlay: HTMLDivElement | null = null;
        let lastFocused: HTMLElement | null = null;

        function disableScroll() {
            document.documentElement.style.overflow = 'hidden';
        }
        function enableScroll() {
            document.documentElement.style.overflow = '';
        }

        function onKeydown(e: KeyboardEvent) {
            if (e.key === 'Escape') closeModal();
        }

        function closeModal() {
            if (!overlay) return;
            overlay.remove();
            overlay = null;
            enableScroll();
            document.removeEventListener('keydown', onKeydown);
            lastFocused?.focus();
        }

        function openModal(trigger: HTMLElement) {
            const img = trigger.querySelector('img');
            if (!img) return;

            lastFocused = trigger;

            overlay = document.createElement('div');
            overlay.className = 'picture-modal-overlay';
            overlay.setAttribute('role', 'dialog');
            overlay.setAttribute('aria-modal', 'true');

            const fullImg = document.createElement('img');
            fullImg.src = img.currentSrc || img.src;
            fullImg.alt = img.alt;
            fullImg.className = 'picture-modal-image';
            overlay.appendChild(fullImg);

            overlay.addEventListener('click', (e) => {
                if (e.target === overlay) closeModal();
            });

            document.body.appendChild(overlay);
            document.addEventListener('keydown', onKeydown);
            disableScroll();
        }

        document.addEventListener('click', (e) => {
            const trigger = (e.target as HTMLElement)?.closest('[data-click-modal="true"]');
            if (trigger) openModal(trigger as HTMLElement);
        });
    }
</script>

