---
// VideoModal.astro
import { getVideoUrl } from "../../lib/video";


interface Props {
	platform: "vimeo" | "youtube";
    idVideo: string;
    autoplay?: number;
}

const { platform, idVideo, autoplay = 0} = Astro.props;

const src = getVideoUrl(platform, idVideo, autoplay);

---

<div class="video-embed">
    <iframe
        src={src}
        frameborder="0"
        allow="autoplay; fullscreen; picture-in-picture"
        allowfullscreen
        loading="lazy"
    />
</div>


<style>
	.video-embed {
		position: relative;
		width: 100%;
		aspect-ratio: 16 / 9;
	}

	.video-embed iframe {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		border: 0;
		border-radius: 10px;
	}
</style>
