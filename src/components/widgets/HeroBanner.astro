---
import Picture from './Picture.astro';

interface Props {
	thumbnail?: ImageMetadata | null; // pass the first carousel frame here, not a separate thumbnail
	title: string;
	description?: string;
	software?: string;
	stack?: string[];
}

const { thumbnail, title, description, software, stack = [] } = Astro.props;
---

<div class="hero-banner">
	{thumbnail && (
		<div class="hero-banner-thumb">
			<Picture src={thumbnail} alt="" draggable={false} />
		</div>
	)}
	<div class="hero-banner-content">
		<h1 class="hero-banner-title">{title}</h1>
		{description && <p class="hero-banner-description">{description}</p>}
		{(software || stack.length > 0) && (
			<div class="hero-banner-tags">
				{software && <span class="tag tag-accent">{software}</span>}
				{stack.map((item) => (
					<span class="tag">{item}</span>
				))}
			</div>
		)}
	</div>
</div>

<style>
	.hero-banner {
		display: flex;
		align-items: center;
		gap: 1.25rem;
		width: 95%;
		padding: 1.25rem 1.5rem;
		background: var(--comp-bg-white);
		border: 1px solid var(--color-border, rgba(0, 0, 0, 0.08));
		border-start-start-radius: 14px;
		overflow: visible;
	}

	.hero-banner-thumb {
		flex-shrink: 0;
		width: 14%;
		aspect-ratio: 1 / 1;
		border-radius: 8px;
		overflow: hidden;
		background: var(--comp-bg-white);
	}

	.hero-banner-thumb :global(img) {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
	}

	.hero-banner-content {
		flex: 1;
		min-width: 0;
	}

	.hero-banner-title {
		margin: 0;
		font-size: 1.4rem;
		font-weight: 600;
		color: var(--color-text-primary, #1c1c28);
	}

	.hero-banner-description {
		margin-right: 0.5rem;
		margin-top: 0.25rem;
		font-size: 1rem;
		color: var(--color-text-secondary, #5a5a68);
	}

	.hero-banner-tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.4rem;
	}

	.tag {
		font-size: 0.8rem;
		padding: 0.15rem 0.55rem;
		border-radius: 6px;
		background: var(--comp-bg-gray);
		color: var(--color-text-secondary, #5a5a68);
	}

	.tag-accent {
		background: var(--comp-bg-gray);
		color: var(--accent-light);
		opacity: 0.8;
		font-weight: 600;
	}

	@media (orientation: portrait), (max-aspect-ratio: 9/16) {
        .hero-banner-thumb {
			display: none;
		}
    }

</style>