---
// ArrowButton.astro
import ScrollDownArrow from '../../assets/icons/AS_DownArrow.svg';

interface Props {
    heightVh?: number;
	angle?: number;
    variant?: 'enabled' | 'glow' | 'disabled';
}

const {heightVh = 3.2, angle = 0, variant = 'enabled'} = Astro.props;

---


<div class={`arrow-btn ${variant}`} style={`--height-vh: ${heightVh}vh; --angle: ${angle}deg;`}>
    <div class="icon-wrapper">
        <img src={ScrollDownArrow.src} alt="" />
    </div>
</div>

<style>
    .arrow-btn img {
		width: auto;
		height: var(--height-vh);
	}

    .arrow-btn {
        cursor: pointer;
        transition: transform 0.2s ease, filter 0.2s ease;
    }


    .icon-wrapper {
        transform: rotate(var(--angle));
    }

    /* --------------------- STATES ---------------------*/

    /* active */
    .arrow-btn.enabled {
        filter: none;
        opacity: 1;
    }

    /* glow state */
    .arrow-btn.glow {
        filter: drop-shadow(0 0 10px var(--color-primary-glow));
    }

    /* disabled state */
    .arrow-btn.disabled {
        opacity: 0.3;
        filter: brightness(80%);
        pointer-events: none;
    }

    .arrow-btn.hidden {
        opacity: 0;
        pointer-events: none;
    }


</style>