---
/**
* Callout.astro
* A block: note, info, tip, warning, danger.
*
* Usage:
* <Callout type="warning" title="Heads up">
*   This tool only works with closed, manifold geometry.
* </Callout>
*
*/

type CalloutType = 'note' | 'info' | 'tip' | 'warning' | 'danger';

interface Props {
type?: CalloutType;
title?: string;
}

const { type = 'note', title } = Astro.props;

const CALLOUTS: Record<CalloutType, { title: string; icon: string }> = {
  note: {
    title: 'Note',
    icon: 'M7 2.5h7l4 4V20a1.5 1.5 0 0 1-1.5 1.5h-9A1.5 1.5 0 0 1 6 20V4A1.5 1.5 0 0 1 7 2.5Zm7 0V6a1 1 0 0 0 1 1h3.5',
  },
  info: {
    title: 'Info',
    icon: 'M12 2a10 10 0 1 0 0 20 10 10 0 0 0 0-20Zm0 5a1 1 0 1 1 0 2 1 1 0 0 1 0-2Zm1 11h-2v-7h2v7Z',
  },
  tip: {
    title: 'Tip',
    icon: 'M9 18h6M10 22h4M12 2a6 6 0 0 0-4 10.47c.39.34.6.83.6 1.34V15h6.8v-1.19c0-.51.21-1 .6-1.34A6 6 0 0 0 12 2Z',
  },
  warning: {
    title: 'Warning',
    icon: 'M12 9v4m0 4h.01M10.29 3.86 1.82 18a1.5 1.5 0 0 0 1.29 2.25h17.78A1.5 1.5 0 0 0 22.18 18L13.71 3.86a1.5 1.5 0 0 0-2.62 0Z',
  },
  danger: {
    title: 'Danger',
    icon: 'M12 2 1 21h22L12 2Zm0 7v6m0 3h.01',
  },
};


const resolvedTitle = title ?? CALLOUTS[type].title;
const iconPath = CALLOUTS[type].icon;
---

<div class="callout" data-type={type}>
    <div class="callout-icon" aria-hidden="true">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
            <path d={iconPath} stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
    </div>
    <div class="callout-body">
        <p class="callout-title">{resolvedTitle}</p>
        <div class="callout-content">
            <slot />
        </div>
    </div>
</div>

<style>
    .callout {
        --c-bg: rgba(0, 0, 0, 0.04);
        --c-border: rgba(0, 0, 0, 0.15);
        --c-fg: currentColor;

        display: flex;
        gap: 0.75rem;
        align-items: flex-start;
        margin: 1.25rem 0;
        padding: 0.9rem 1rem;
        border-radius: 0.5rem;
        border-left: 3px solid var(--c-border);
        background: var(--c-bg);
    }

    .callout-icon {
        flex-shrink: 0;
        color: var(--c-fg);
        margin-top: 0.15rem;
    }

    .callout-body {
        min-width: 0;
    }

    .callout-title {
        margin: 0 0 0.25rem;
        font-weight: 700;
        font-size: 0.9rem;
        color: var(--c-fg);
    }

    .callout-content {
        font-size: 0.95rem;
        line-height: 1.3;
    }

    .callout-content :global(p) {
        margin: 0;
    }

    .callout-content :global(p + p) {
        margin-top: 0.5rem;
    }

    .callout-content :global(a) {
        color: var(--c-fg);
        text-decoration: underline;
    }

    /* --------------------- TYPES ---------------------*/

    .callout[data-type='note'] {
        --c-bg: var(--callout-note-bg, rgba(120, 120, 130, 0.1));
        --c-border: var(--callout-note-border, #8a8a96);
        --c-fg: var(--callout-note-fg, #6b6b76);
    }

    .callout[data-type='info'] {
        --c-bg: var(--callout-info-bg, rgba(56, 132, 255, 0.1));
        --c-border: var(--callout-info-border, #3884ff);
        --c-fg: var(--callout-info-fg, #2266dd);
    }

    .callout[data-type='tip'] {
        --c-bg: var(--callout-tip-bg, rgba(34, 175, 110, 0.1));
        --c-border: var(--callout-tip-border, #22af6e);
        --c-fg: var(--callout-tip-fg, #18935b);
    }

    .callout[data-type='warning'] {
        --c-bg: var(--callout-warning-bg, rgba(245, 166, 35, 0.12));
        --c-border: var(--callout-warning-border, #f5a623);
        --c-fg: var(--callout-warning-fg, #b3760e);
    }

    .callout[data-type='danger'] {
        --c-bg: var(--callout-danger-bg, rgba(235, 70, 70, 0.1));
        --c-border: var(--callout-danger-border, #eb4646);
        --c-fg: var(--callout-danger-fg, #c62f2f);
    }


</style>