---
/**
* Callout.astro
* A block: note, info, tip, warning, danger.
*
* Usage:
* <Callout type="warning" title="Heads up">
*   This tool only works with closed, manifold geometry.
* </Callout>
*
*/

import Icon from './Icon.astro';

type CalloutType = 'note' | 'info' | 'tip' | 'warning' | 'danger';

interface Props {
    type?: CalloutType;
    title?: string;
}

const { type = 'note', title } = Astro.props;

const TITLES: Record<CalloutType, string> = {
    note: 'Note',
    info: 'Info',
    tip: 'Tip',
    warning: 'Warning',
    danger: 'Danger',
};

const resolvedTitle = title ?? TITLES[type];

---

<div class="callout" data-type={type}>
    <div class="callout-icon" aria-hidden="true">
        <Icon name={type} size={18} />
    </div>
    <div class="callout-body">
        <p class="callout-title">{resolvedTitle}</p>
        <div class="callout-content">
            <slot />
        </div>
    </div>
</div>

<style>
    .callout {
        --c-bg: rgba(0, 0, 0, 0.04);
        --c-border: rgba(0, 0, 0, 0.15);
        --c-fg: currentColor;

        display: flex;
        gap: 0.75rem;
        align-items: flex-start;
        margin: 1.25rem 0;
        padding: 0.9rem 0.8rem;
        border-radius: 0.5rem;
        border-left: 3px solid var(--c-border);
        background: var(--c-bg);
    }

    .callout-icon {
        flex-shrink: 0;
        color: var(--c-fg);
        margin-top: 0.15rem;
    }

    .callout-body {
        min-width: 0;
    }

    .callout-title {
        margin: 0 0 0.25rem;
        font-weight: 700;
        color: var(--c-fg);
    }

    .callout-content {
        line-height: 1.3;
    }

    .callout-content :global(p) {
        margin: 0;
    }

    .callout-content :global(p + p) {
        margin-top: 0.5rem;
    }

    .callout-content :global(a) {
        color: var(--c-fg);
        text-decoration: underline;
    }

    /* --------------------- TYPES ---------------------*/

    .callout[data-type='note'] {
        --c-bg: var(--callout-note-bg, rgba(120, 120, 130, 0.1));
        --c-border: var(--callout-note-border, #8a8a96);
        --c-fg: var(--callout-note-fg, #6b6b76);
    }

    .callout[data-type='info'] {
        --c-bg: var(--callout-info-bg, rgba(56, 132, 255, 0.1));
        --c-border: var(--callout-info-border, #3884ff);
        --c-fg: var(--callout-info-fg, #2266dd);
    }

    .callout[data-type='tip'] {
        --c-bg: var(--callout-tip-bg, rgba(34, 175, 110, 0.1));
        --c-border: var(--callout-tip-border, #22af6e);
        --c-fg: var(--callout-tip-fg, #18935b);
    }

    .callout[data-type='warning'] {
        --c-bg: var(--callout-warning-bg, rgba(245, 166, 35, 0.12));
        --c-border: var(--callout-warning-border, #f5a623);
        --c-fg: var(--callout-warning-fg, #b3760e);
    }

    .callout[data-type='danger'] {
        --c-bg: var(--callout-danger-bg, rgba(235, 70, 70, 0.1));
        --c-border: var(--callout-danger-border, #eb4646);
        --c-fg: var(--callout-danger-fg, #c62f2f);
    }


</style>